type FluxModel =
  | "gguf"
  | "flux2-fast"
  | "q5"
  | "flux2-hq"
  | "fp8"
  | "flux2-klein-true-v2";
type ZImageProfile =
  | "z-image-base-amateur-photo-8step"
  | "z-image-turbo-amateur-photo";
type ImageModel = FluxModel | ZImageProfile | string;

