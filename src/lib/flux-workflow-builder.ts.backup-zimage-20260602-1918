// FrameForge — Flux 2 Workflow Builder
// Builds ComfyUI API-format workflow JSON for Flux 2 image generation.

type FluxModel = "gguf" | "q5" | "fp8";

const MODEL_CONFIG: Record<
  FluxModel,
  { file: string; loaderClass: string; fileKey: string }
> = {
  gguf: {
    file: "flux2-dev-Q3_K_M.gguf",
    loaderClass: "UnetLoaderGGUF",
    fileKey: "unet_name",
  },
  q5: {
    file: "flux2-dev-Q5_K_M.gguf",
    loaderClass: "UnetLoaderGGUF",
    fileKey: "unet_name",
  },
  fp8: {
    file: "flux2_dev_fp8mixed.safetensors",
    loaderClass: "UNETLoader",
    fileKey: "unet_name",
  },
};

const FLUX_ENCODER = "mistral_3_small_flux2_fp8.safetensors";
const FLUX_VAE = "flux2-vae.safetensors";

export interface FluxWorkflowParams {
  prompt: string;
  negativePrompt?: string;
  width?: number;
  height?: number;
  steps?: number;
  cfg?: number;
  seed?: number;
  referenceImage?: string;
  denoise?: number;
  model?: FluxModel;
}

function clampDimension(value: number | undefined, fallback: number): number {
  const resolved = value ?? fallback;
  return Math.min(2048, Math.max(256, Math.round(resolved / 32) * 32));
}

export function buildFluxWorkflow(
  params: FluxWorkflowParams,
): Record<string, unknown> {
  const {
    prompt,
    negativePrompt = "",
    steps = 28,
    cfg = 1.0,
    seed = Math.floor(Math.random() * 1_000_000_000_000),
    referenceImage,
    denoise,
    model = "gguf",
  } = params;
  const width = clampDimension(params.width, 1024);
  const height = clampDimension(params.height, 1024);

  const config = MODEL_CONFIG[model] ?? MODEL_CONFIG.gguf;
  const unetLoaderInputs: Record<string, unknown> = {
    [config.fileKey]: config.file,
  };
  if (model === "fp8") {
    unetLoaderInputs.weight_dtype = "default";
  }

  const workflow: Record<string, unknown> = {
    "1": {
      class_type: config.loaderClass,
      inputs: unetLoaderInputs,
    },
    "2": {
      class_type: "CLIPLoader",
      inputs: {
        clip_name: FLUX_ENCODER,
        type: "flux2",
        device: "cpu",
      },
    },
    "3": {
      class_type: "VAELoader",
      inputs: {
        vae_name: FLUX_VAE,
      },
    },
    "4": {
      class_type: "CLIPTextEncode",
      inputs: {
        text: prompt,
        clip: ["2", 0],
      },
    },
    "5": {
      class_type: "CLIPTextEncode",
      inputs: {
        text: negativePrompt,
        clip: ["2", 0],
      },
    },
    "7": {
      class_type: "KSampler",
      inputs: {
        model: ["1", 0],
        positive: ["4", 0],
        negative: ["5", 0],
        latent_image: ["6", 0],
        seed,
        steps,
        cfg,
        sampler_name: "euler",
        scheduler: "simple",
        denoise: referenceImage ? (denoise ?? 0.75) : 1.0,
      },
    },
    "8": {
      class_type: "VAEDecode",
      inputs: {
        samples: ["7", 0],
        vae: ["3", 0],
      },
    },
    "9": {
      class_type: "SaveImage",
      inputs: {
        images: ["8", 0],
        filename_prefix: "FrameForge_Flux2",
      },
    },
  };

  if (referenceImage) {
    workflow["10"] = {
      class_type: "LoadImage",
      inputs: {
        image: referenceImage,
      },
    };
    workflow["6"] = {
      class_type: "ImageScale",
      inputs: {
        image: ["10", 0],
        upscale_method: "lanczos",
        width,
        height,
        crop: "center",
      },
    };
    workflow["12"] = {
      class_type: "VAEEncode",
      inputs: {
        pixels: ["6", 0],
        vae: ["3", 0],
      },
    };
    (workflow["7"] as { inputs: Record<string, unknown> }).inputs.latent_image = [
      "12",
      0,
    ];
  } else {
    workflow["6"] = {
      class_type: "EmptyLatentImage",
      inputs: {
        width,
        height,
        batch_size: 1,
      },
    };
  }

  return workflow;
}
