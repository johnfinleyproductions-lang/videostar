# FrameForge Environment Configuration
# Copy this to .env.local and update values
# IMPORTANT: Use 127.0.0.1, NEVER localhost (IPv6 issue on CachyOS)

# ComfyUI backend
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_WS_URL=ws://127.0.0.1:8188/ws

# Optional LTX Desktop backend
# LTX Desktop runs a separate FastAPI backend. Leave unset until installed.
# LTX_DESKTOP_URL=http://127.0.0.1:8000
# LTX_DESKTOP_OUTPUT_DIR=C:\Users\evergreen\AppData\Roaming\LTX Studio\outputs
# LTX_DESKTOP_AUTH_TOKEN=
# LTX_DESKTOP_NEGATIVE_PROMPT=

# App
PORT=3060
NEXT_PUBLIC_APP_URL=http://192.168.4.176:3060
NEXT_PUBLIC_COMFYUI_WS_URL=ws://192.168.4.176:8188/ws
