#!/usr/bin/env bash
# FrameForge one-shot startup
#
# Brings up the entire FrameForge stack on the Framestation with a single
# command. Designed to be installed at /usr/local/bin/frame so it can be
# invoked from any folder after SSH'ing in.
#
# Install (one-time, from the Framestation):
#     sudo install -m 755 scripts/frame /usr/local/bin/frame
#
# Run:
#     frame          # default 300 MHz (safest)
#     frame 450      # lock at 450 MHz (1.5x faster)
#     frame 600      # lock at 600 MHz (2x faster)
#     frame 900      # lock at 900 MHz (3x faster, may crash)
#
# What it does:
#   1. Stops Ollama to release any VRAM it's holding on the NVIDIA card.
#   2. Stabilizes the GPU for Thunderbolt operation:
#      - Enables persistence mode (keeps driver loaded between CUDA calls)
#      - Locks GPU clocks to a FIXED speed (prevents power state transitions
#        that crash the PCIe link over USB4/Thunderbolt — see
#        NVIDIA/open-gpu-kernel-modules #979)
#      - Sets power limit to minimum (150W) as safety net
#   3. Kills any stale tmux sessions.
#   4. Launches ComfyUI in a detached tmux session named `comfy` under bash.
#   5. Launches Next.js (FrameForge) in a detached tmux session named `framenext`.
#   6. Prints the URLs and tmux attach commands.
#
# IMPORTANT: Clock speed MUST be set BEFORE any CUDA workload starts.
# Changing clocks mid-inference will crash the USB4 link.
# That's why this script sets clocks first, then starts ComfyUI.
#
# IMPORTANT: both tmux sessions are wrapped in `bash -lc '...'` because the
# default login shell on CachyOS is fish, and fish cannot source bash-syntax
# files like `.venv/bin/activate`.
#
# Watch logs:     tmux attach -t comfy   (or -t framenext)
# Detach:         Ctrl+B then d
# Restart Ollama: sudo systemctl start ollama

set -e

# Accept optional clock speed argument (default: 300 MHz)
GPU_CLOCK="${1:-300}"

echo "→ Stopping Ollama to free GPU VRAM..."
sudo systemctl stop ollama 2>/dev/null || true

echo "→ Stabilizing GPU for Thunderbolt operation..."
if nvidia-smi &>/dev/null; then
    sudo nvidia-smi -pm 1
    sudo nvidia-smi -lgc "${GPU_CLOCK},${GPU_CLOCK}"
    sudo nvidia-smi -pl 150
    echo "  ✓ Persistence mode ON, clocks locked at ${GPU_CLOCK} MHz, power limit 150W"
else
    echo "  ✗ WARNING: nvidia-smi not responding — GPU may not be available"
    echo "  Continuing anyway in case it recovers..."
fi

echo "→ Killing stale tmux sessions..."
tmux kill-session -t comfy 2>/dev/null || true
tmux kill-session -t framenext 2>/dev/null || true
# Also kill legacy session name
tmux kill-session -t frame 2>/dev/null || true

echo "→ Starting ComfyUI in tmux (under bash)..."
tmux new-session -d -s comfy "bash -lc 'cd /home/lynf/ComfyUI && source .venv/bin/activate && python main.py --listen 0.0.0.0 --port 8188; exec bash'"

echo "→ Waiting for ComfyUI to start..."
sleep 5

echo "→ Starting FrameForge (Next.js) in tmux (under bash)..."
tmux new-session -d -s framenext "bash -lc 'cd /home/lynf/videostar && PORT=3060 npm run dev; exec bash'"

echo ""
echo "✓ FrameForge stack started."
echo "  ComfyUI:    http://192.168.4.176:8188"
echo "  FrameForge: http://192.168.4.176:3060"
echo ""
echo "  Watch ComfyUI:    tmux attach -t comfy"
echo "  Watch Next.js:    tmux attach -t framenext"
echo "  Detach from tmux: Ctrl+B then d"
echo "  Restart Ollama:   sudo systemctl start ollama"
echo ""
echo "  GPU clocks locked at ${GPU_CLOCK} MHz."
if [ "$GPU_CLOCK" -eq 300 ] 2>/dev/null; then
    echo "  To try faster (set BEFORE generating, not during):"
    echo "    frame 450    # 1.5x speed"
    echo "    frame 600    # 2x speed"
fi
echo ""
